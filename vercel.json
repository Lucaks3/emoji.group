{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run site",
  "outputDirectory": "site/public",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/:slug([a-z0-9-]+)",
      "has": [{ "type": "header", "key": "accept", "value": ".*application/json.*" }],
      "destination": "/:slug.json"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.json",
      "headers": [
        { "key": "access-control-allow-origin", "value": "*" },
        { "key": "cache-control", "value": "public, max-age=3600, s-maxage=31536000, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|svg|png|txt|xml)",
      "headers": [
        { "key": "cache-control", "value": "public, max-age=86400, s-maxage=31536000, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/((?!.*\\.).*)",
      "headers": [
        { "key": "cache-control", "value": "public, max-age=600, s-maxage=31536000, stale-while-revalidate=86400" }
      ]
    }
  ]
}
